{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Auto Public",
  "version": "1.0.0",
  "identifier": "com.ikedachiin.auto-public",
  "build": {
    "frontendDist": "http://localhost:3000",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Auto Public - 電子書籍自動生成",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../scripts/kdp-uploader/kdp-upload.js",
      "../scripts/kdp-uploader/human-like.js",
      "../scripts/kdp-uploader/book-config.json",
      "../scripts/rebuild-epub.js"
    ],
    "externalBin": []
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
